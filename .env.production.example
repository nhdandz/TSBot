# =============================================================================
# TSBot — Production Environment Variables
# Copy file này thành .env.production rồi điền giá trị thật
#
# Tạo secret key:  openssl rand -base64 32
# Tạo password:    openssl rand -base64 20
# =============================================================================

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=production
DEBUG=false
LOG_LEVEL=info
API_WORKERS=4

# ── vLLM Server (Máy A100) ───────────────────────────────────────────────────
# Thay <A100_IP> bằng IP thật của máy A100
VLLM_BASE_URL=http://<A100_IP>:8001/v1
VLLM_MAIN_MODEL=Qwen/Qwen2.5-7B-Instruct
VLLM_GRADER_MODEL=Qwen/Qwen2.5-1.5B-Instruct
VLLM_API_KEY=EMPTY

# ── Embeddings ───────────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cuda

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=tsbot_prod
POSTGRES_PASSWORD=<RANDOM_PASSWORD>
POSTGRES_DB=tsbot_production
POSTGRES_POOL_SIZE=20
POSTGRES_MAX_OVERFLOW=40

# ── Qdrant ───────────────────────────────────────────────────────────────────
# (tự động dùng internal hostname 'qdrant' trong docker compose)

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
USE_REDIS_CACHE=true

# ── Security — BẮT BUỘC thay đổi! ───────────────────────────────────────────
SECRET_KEY=<openssl rand -base64 32>
ADMIN_USERNAME=tsbot_admin
ADMIN_PASSWORD=<openssl rand -base64 20>

# ── CORS — đặt domain thật của bạn ──────────────────────────────────────────
# Dùng dấu phẩy để ngăn cách nhiều origins
CORS_ORIGINS=["https://yourdomain.com","https://www.yourdomain.com"]

# ── Frontend (Vite build) ────────────────────────────────────────────────────
# File: frontend/.env.production
# VITE_API_BASE_URL=https://yourdomain.com
