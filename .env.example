# =============================================================================
# TSBot — Development Environment Configuration
# Copy thành .env và điền giá trị phù hợp
# =============================================================================

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=TSBot
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ── API ──────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=tsbot
POSTGRES_PASSWORD=tsbot_secret_password
POSTGRES_DB=tsbot_db
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20

# ── Qdrant ───────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_LEGAL_COLLECTION=legal_documents
QDRANT_SQL_EXAMPLES_COLLECTION=sql_examples
QDRANT_INTENTS_COLLECTION=intents

# ── vLLM Server (OpenAI-compatible) ─────────────────────────────────────────
# Development: chạy vLLM local hoặc dùng IP máy A100
VLLM_BASE_URL=http://localhost:8001/v1
VLLM_MAIN_MODEL=Qwen/Qwen2.5-7B-Instruct
VLLM_MAIN_TEMPERATURE=0.1
VLLM_MAIN_TOP_P=0.9
VLLM_GRADER_MODEL=Qwen/Qwen2.5-1.5B-Instruct
VLLM_GRADER_TEMPERATURE=0.0
VLLM_API_KEY=EMPTY

# ── Embeddings (sentence-transformers local) ─────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSION=1024
EMBEDDING_DEVICE=auto

# ── Redis (optional cho dev, bắt buộc cho prod) ──────────────────────────────
REDIS_URL=redis://localhost:6379
USE_REDIS_CACHE=false

# ── RAG ──────────────────────────────────────────────────────────────────────
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120
RAG_TOP_K=5
RAG_RELEVANCE_THRESHOLD=0.7

# ── Reranker ─────────────────────────────────────────────────────────────────
RERANKER_MODEL=namdp-ptit/ViRanker
RERANKER_TOP_K=3

# ── SQL Agent ────────────────────────────────────────────────────────────────
SQL_MAX_RETRIES=3
SQL_FEW_SHOT_EXAMPLES=5

# ── Semantic Router ──────────────────────────────────────────────────────────
ROUTER_SIMILARITY_THRESHOLD=0.85

# ── Authentication — ĐỔI TRƯỚC KHI DEPLOY! ──────────────────────────────────
SECRET_KEY=dev-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ── Paths ────────────────────────────────────────────────────────────────────
DATA_DIR=./data
DOCUMENTS_DIR=./data/documents
SQL_EXAMPLES_DIR=./data/sql_examples
INTENTS_DIR=./data/intents
